# SSH MCP Server Configuration
# Copy this file to .env and update with your values

# SSH Server Configuration
SSH_HOST=your-server.example.com
SSH_USER=root
SSH_PASSWORD=your_password_here
# OR use SSH key instead of password:
SSH_KEY_FILE=/app/ssh_keys/id_ed25519
SSH_PORT=22

# Optional MCP API authentication token.
# If set, requests must include: Authorization: Bearer <token>
# AUTH_TOKEN=your_secure_random_token

# Server Configuration (optional)
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
